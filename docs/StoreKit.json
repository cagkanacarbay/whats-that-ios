  "primaryContentSections": [
    {
      "content": [
        {
          "type": "heading",
          "anchor": "overview",
          "text": "Overview",
          "level": 2
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "text": "Use the StoreKit framework to provide the following features and services for your apps and In-App Purchases:",
              "type": "text"
            }
          ]
        },
        {
          "type": "termList",
          "items": [
            {
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "type": "text",
                        "text": "Offer and promote In-App Purchases for content and services."
                      }
                    ]
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "type": "text",
                    "text": "In-App Purchase"
                  }
                ]
              }
            },
            {
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "type": "text",
                        "text": "Verify a customer’s app purchase with an App Store-signed transaction."
                      }
                    ]
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "text": "App transaction",
                    "type": "text"
                  }
                ]
              }
            },
            {
              "definition": {
                "content": [
                  {
                    "inlineContent": [
                      {
                        "type": "text",
                        "text": "Control the display of App Store messages in your app."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "type": "text",
                    "text": "Messages"
                  }
                ]
              }
            },
            {
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "type": "text",
                        "text": "Request App Store reviews and ratings from your customers."
                      }
                    ]
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "text": "Reviews",
                    "type": "text"
                  }
                ]
              }
            },
            {
              "definition": {
                "content": [
                  {
                    "inlineContent": [
                      {
                        "text": "Provide recommendations for third-party content that customers can purchase from the App Store.",
                        "type": "text"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "type": "text",
                    "text": "Recommendations"
                  }
                ]
              }
            },
            {
              "definition": {
                "content": [
                  {
                    "type": "paragraph",
                    "inlineContent": [
                      {
                        "type": "text",
                        "text": "Validate advertisement-driven app installations. See "
                      },
                      {
                        "isActive": true,
                        "type": "reference",
                        "identifier": "doc://com.apple.documentation/documentation/AdAttributionKit"
                      },
                      {
                        "type": "text",
                        "text": " for app ad campaigns on the App Store and alternative marketplaces."
                      }
                    ]
                  }
                ]
              },
              "term": {
                "inlineContent": [
                  {
                    "text": "Ad network attribution",
                    "type": "text"
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "paragraph",
          "inlineContent": [
            {
              "type": "text",
              "text": "The StoreKit framework also provides functionality for "
            },
            {
              "identifier": "doc://com.apple.storekit/documentation/StoreKit/external-purchase",
              "type": "reference",
              "isActive": true
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "identifier": "doc://com.apple.storekit/documentation/StoreKit/external-link-account",
              "type": "reference",
              "isActive": true
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "identifier": "doc://com.apple.storekit/documentation/StoreKit/PaymentMethodBinding",
              "type": "reference",
              "isActive": true
            },
            {
              "type": "text",
              "text": ", and "
            },
            {
              "identifier": "doc://com.apple.storekit/documentation/StoreKit/StoreDownloaderExtension",
              "type": "reference",
              "isActive": true
            },
            {
              "type": "text",
              "text": "."
            }
          ]
        }
      ],
      "kind": "content"
    }
  ],
