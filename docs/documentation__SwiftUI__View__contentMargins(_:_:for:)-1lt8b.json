                  "type": "text"
                }
              ]
            }
          ],
          "name": "length"
        },
        {
          "content": [
            {
              "type": "paragraph",
              "inlineContent": [
                {
                  "text": "Where the margins should be added.",
                  "type": "text"
                }
              ]
            }
          ],
          "name": "placement"
        }
      ]
    },
    {
      "kind": "content",
      "content": [
        {
          "anchor": "discussion",
          "type": "heading",
          "text": "Discussion",
          "level": 2
        },
        {
          "inlineContent": [
            {
              "type": "text",
              "text": "Use this modifier to customize the content margins of different"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "kinds of views. For example, you can use this modifier to customize"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "the margins of scrollable views like "
            },
            {
              "identifier": "doc://com.apple.SwiftUI/documentation/SwiftUI/ScrollView",
              "type": "reference",
              "isActive": true
            },
            {
              "type": "text",
              "text": ". In the"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "following example, the scroll view will automatically inset"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "its content by the safe area plus an additional 20 points"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "text",
              "text": "on the leading and trailing edge."
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "codeListing",
          "code": [
            "ScrollView(.horizontal) {",
            "    // ...",
            "}",
            ".contentMargins(.horizontal, 20.0)"
          ],
          "syntax": "swift"
        },
        {
          "inlineContent": [
            {
              "text": "You can provide a ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.SwiftUI/documentation/SwiftUI/ContentMarginPlacement",
              "type": "reference",
              "isActive": true
            },
            {
              "text": " to target specific",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "parts of a view to customize. For example, provide a",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.SwiftUI/documentation/SwiftUI/ContentMarginPlacement/scrollContent",
              "type": "reference",
              "isActive": true
            },
            {
              "text": " placement to",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "inset the content of a ",
              "type": "text"
            },
            {
              "identifier": "doc://com.apple.SwiftUI/documentation/SwiftUI/TextEditor",
              "type": "reference",
              "isActive": true
            },
            {
              "text": " without affecting the",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "insets of its scroll indicators.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "codeListing",
          "code": [
            "TextEditor(text: $text)",
            "    .contentMargins(.horizontal, 20.0, for: .scrollContent)"
          ],
          "syntax": "swift"
        },
        {
          "inlineContent": [
            {
              "text": "Similarly, you can customize the insets of scroll indicators",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "separately from scroll content. Consider doing this when applying",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "a custom clip shape that may clip the indicators.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "type": "codeListing",
          "code": [
            "ScrollView {",
            "    // ...",
            "}",
            ".clipShape(.rect(cornerRadius: 20.0))",
            ".contentMargins(10.0, for: .scrollIndicators)"
          ],
          "syntax": "swift"
        },
        {
          "inlineContent": [
            {
              "text": "When applying multiple contentMargins modifiers, modifiers with",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "the same placement will override modifiers higher up in the view",
              "type": "text"
            },
            {
              "text": " ",
              "type": "text"
            },
            {
              "text": "hierarchy.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        }
      ]
    }
  ],
